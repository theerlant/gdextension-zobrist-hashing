windows.debug.x86_32 = "res://addons/zobrist-hashing/bin/zobrist.windows.template_debug.x86_32.dll"
windows.release.x86_32 = "res://addons/zobrist-hashing/bin/zobrist.windows.template_release.x86_32.dll"
linux.debug.x86_64 = "res://addons/zobrist-hashing/bin/zobrist.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/zobrist-hashing/bin/zobrist.linux.template_release.x86_64.so"
